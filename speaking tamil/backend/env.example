# Ollama (local LLM) - no API key needed!
# Install Ollama from https://ollama.ai, then run: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
WHISPER_MODEL=base

# Tamil TTS Configuration (optional - for better native Tamil voice)
# Option 1: Google Cloud TTS (requires API key)
# GOOGLE_TTS_API_KEY=your_google_cloud_api_key_here

# Option 2: Azure Cognitive Services TTS (requires API key and region)
# AZURE_TTS_KEY=your_azure_key_here
# AZURE_TTS_REGION=eastus

# If neither is configured, will use gTTS (free, requires internet) or browser TTS


